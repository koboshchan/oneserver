"{{domain}}" {
  auto_tls
  header "X-Content-Type-Options" "nosniff"

  location "/api/" {
    proxy "{{upstream_url}}"
    proxy_request_header "Host" "{header:Host}"
    proxy_request_header "X-Real-IP" "{client_ip}"
    proxy_request_header "X-Forwarded-For" "{header:X-Forwarded-For}, {client_ip}"
    proxy_request_header "X-Forwarded-Proto" "{scheme}"
  }

  location "/ws" {
    proxy "{{upstream_url}}"
    proxy_request_header "Upgrade" "{header:Upgrade}"
    proxy_request_header "Connection" "upgrade"
    proxy_request_header "Host" "{header:Host}"
  }

  location "/socket.io" {
    proxy "{{upstream_url}}"
    proxy_request_header "Upgrade" "{header:Upgrade}"
    proxy_request_header "Connection" "upgrade"
    proxy_request_header "Host" "{header:Host}"
  }

  location "/" {
    proxy "{{upstream_url}}"
    proxy_request_header "Host" "{header:Host}"
    proxy_request_header "X-Real-IP" "{client_ip}"
    proxy_request_header "X-Forwarded-For" "{header:X-Forwarded-For}, {client_ip}"
    proxy_request_header "X-Forwarded-Proto" "{scheme}"
  }
}

"{{domain}}:80" {
  status 301 location="https://{{domain}}{path_and_query}"
}
