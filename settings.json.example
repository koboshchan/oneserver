[
    {
        // ==========================================
        // 1. Standard Upstream Proxy (HTTPS only)
        // ==========================================
        "domain": "app.example.com",
        "forwarding": "localhost:3000",
        "type": "https-only",
        "rate-limit": {
            "/api/auth/*": 10,
            "/api/*": 100,
            "/": 50
        },
        "websocket": true,
        "compression": true,
        "security-headers": true,
        "csp-unsafe-eval": false,
        "timeout": "120s",
        "max-body-size": "25m"
    },
    {
        // ==========================================
        // 2. Proxy with Header Controls
        // ==========================================
        "domain": "internal-api.example.com",
        "forwarding": "192.168.1.100:8080",
        "type": "https",
        // Optional: Exclude X-Forwarded-For and X-Real-IP headers from forwarding
        "no-x-forwarded-for": true
    },
    {
        // ==========================================
        // 3. Permanent / Temporary Redirects
        // ==========================================
        "domain": "redirect.example.com",
        // The destination URL to redirect to
        "forwarding": "https://google.com/search",
        // "redirect-perm" (301) or "redirect-temp" (302)
        "type": "redirect-perm",
        "ca-bundle": "fullchain.pem",
        "private-key": "privkey.pem",
        // Optional: Append URL path to forwarding address (e.g. domain/hello -> google.com/search/hello)
        "forward-url-path": true,
        "rate-limit": {
            "/": 60
        }
    },
    {
        // ==========================================
        // 4. Static File Server (HTTPS Only)
        // ==========================================
        "domain": "static.example.com",
        "type": "static-https-only",
        "ca-bundle": "fullchain.pem",
        "private-key": "privkey.pem",
        // Mappings of request routes to static files or directories under /public/
        "path": {
            "/hello": "hello.html",     // Exact match: serves /public/hello.html
            "/hello/": "hello/",        // Directory match: serves directory contents
            "/hello/*": "hello.html",   // 1-Level wildcard: serves hello.html for /hello/abc, returns 404 for deeper paths
            "/assets/**": "assets/"     // Recursive wildcard: serves files under assets/ at any depth
        },
        "rate-limit": {
            "/": 150
        }
    },
    {
        // ==========================================
        // 5. Custom Error Page Handlers
        // ==========================================
        // Error handlers are mapped to their domains as separate service blocks
        "domain": "app.example.com",
        // Custom 404 handler that redirects the user permanently
        "type": "404:redirect-perm",
        "forwarding": "https://example.com/not-found"
    },
    {
        "domain": "app.example.com",
        // Custom 500 handler serving a static HTML file
        "type": "500:static-https",
        "ca-bundle": "fullchain.pem",
        "private-key": "privkey.pem",
        "path": {
            "/": "errors/500.html"
        }
    },
    {
        "domain": "app.example.com",
        // Wildcard fallback handler mapping all other error codes (403, 502, etc.) to a static page
        "type": "*:static-http",
        "path": {
            "/": "errors/general.html"
        }
    }
]
